generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  name         String
  price        Int
  category     String
  image        String
  description  String   @db.Text
  weight       Int?
  height       Int?
  aroma        String?
  colorOptions Json?
  inStock      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([inStock])
}
